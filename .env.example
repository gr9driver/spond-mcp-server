# Spond credentials (required)
SPOND_USERNAME=your@email.com
SPOND_PASSWORD=yourpassword

# Optional: Spond Club ID for transaction queries
SPOND_CLUB_ID=

# Optional: integration test configuration
# Set these to run tests/test_event_fields_integration.py against your own Spond account
TEST_EVENT_ID=          # ID of an existing event to use as integration test target
TEST_GROUP_ID=          # Parent group ID
TEST_SUBGROUP_ID=       # Subgroup ID within the parent group
TEST_HOME_VENUE=My Cricket Club          # Home venue feature name (as shown in Spond)
TEST_HOME_ADDRESS=1 Cricket Lane, MyTown, AB1 2CD  # Full address string
TEST_MATCH_START=2026-05-10T09:00:00    # UTC start timestamp
TEST_MATCH_END=2026-05-10T11:00:00      # UTC end timestamp
TEST_MATCH_HEADING=My Club U11 V Rival CC  # Match heading (opponent parsed after " V ")
